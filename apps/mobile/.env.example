# Supabase (publishable key — safe to ship in the app binary)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Moni AI backend (apps/backend). Leave empty to disable AI features (mock client).
# Local dev: http://localhost:8080 (Android emulator: http://10.0.2.2:8080,
# physical device: http://<your-machine-LAN-IP>:8080)
EXPO_PUBLIC_AI_API_URL=
