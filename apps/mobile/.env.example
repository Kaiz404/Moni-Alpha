# Supabase (publishable key — safe to ship in the app binary)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Moni AI backend (apps/backend). Leave empty to disable AI features (mock client).
# Local dev: http://localhost:8080 (Android emulator: http://10.0.2.2:8080,
# physical device: http://<your-machine-LAN-IP>:8080)
EXPO_PUBLIC_AI_API_URL=

# Google Sign-In (native). Web OAuth client ID from GCP — same ID configured in Supabase Auth → Google.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=822716203653-xxxxxxxx.apps.googleusercontent.com
# iOS only: reversed client ID from the iOS OAuth client (optional on Android-only dev).
# EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.822716203653-xxxxxxxx
