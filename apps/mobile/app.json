{
  "expo": {
    "name": "Moni",
    "slug": "moni",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moni",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.moni",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to use the camera to scan receipts."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.moni",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-router",
      [
        "react-native-maps",
        {
          "iosGoogleMapsApiKey": "AIzaSyAsS70ARqJsU4OJGNmxP04DD171Yc6aMWU",
          "androidGoogleMapsApiKey": "AIzaSyAsS70ARqJsU4OJGNmxP04DD171Yc6aMWU"
        }
      ],
      "./plugins/with-notification-listener-manifest",
      "expo-speech-recognition",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location for transaction tracking."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "autolinking": {
      "nativeModulesDir": "./modules"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d87a003d-1cc2-4aea-9fc3-497325c5703b"
      }
    },
    "owner": "kaiz404"
  }
}
