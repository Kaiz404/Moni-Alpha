{
  "name": "moni",
  "main": "./index.js",
  "version": "1.0.0",
  "scripts": {
    "dev": "node ./scripts/adb-reverse.mjs && expo start --localhost",
    "start": "node ./scripts/adb-reverse.mjs && expo start --localhost",
    "android": "node ./scripts/adb-reverse.mjs && REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "test": "jest --runInBand",
    "test:notification-detection": "node ./scripts/notification-detection-suite.mjs",
    "test:notification-routing": "node ./scripts/notification-routing-suite.mjs",
    "test:default-wallet": "node ./scripts/default-wallet-suite.mjs"
  },
  "dependencies": {
    "@expo/dom-webview": "~57.0.1",
    "@expo/metro-runtime": "~57.0.5",
    "@legendapp/state": "3.0.0-beta.47",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-vector-icons/material-icons": "^13.1.2",
    "@repo/types": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.64.3",
    "expo": "~57.0.6",
    "expo-build-properties": "~57.0.5",
    "expo-constants": "~57.0.5",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.4",
    "expo-image-picker": "^57.0.4",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-location": "~57.0.4",
    "expo-router": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-speech-recognition": "^3.1.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "moni-android-apps": "file:./modules/moni-android-apps",
    "moni-document-scanner": "file:./modules/moni-document-scanner",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-android-notification-listener": "^5.0.1",
    "react-native-background-actions": "^4.0.1",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-maps": "^1.27.2",
    "react-native-mmkv": "4.3.2",
    "react-native-nitro-modules": "0.35.9",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~57.0.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  }
}
