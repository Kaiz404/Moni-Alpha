# Moni AI backend configuration

# Supabase project URL — used to fetch the JWKS for JWT verification.
SUPABASE_URL=https://your-project.supabase.co

# Groq API key (console.groq.com/keys). Developer tier recommended.
GROQ_API_KEY=gsk_your_key_here

# Optional overrides
# PORT=8080
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GIN_MODE=debug
